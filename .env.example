# FP&A Open Toolkit — Variáveis de Ambiente
# Copie para .env e preencha com valores de desenvolvimento local.
# ⚠️  NUNCA commite valores reais. Apenas dados sintéticos.
# =============================================================================

# --- Ambiente ---
ENVIRONMENT=development

# --- Banco de dados (opcional — usa SQLite por padrão) ---
DATABASE_URL=sqlite:///data/fpa.db

# --- Logging ---
LOG_LEVEL=INFO
